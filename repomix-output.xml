<file path="src/app/globals.css">
@import "tailwindcss";

/* ─────────────────────────────────────────
   TAILWIND v4 THEME
───────────────────────────────────────── */
@theme {
  --color-navy:  #0A0E1A;
  --color-steel: #1E3A5F;
  --color-gold:  #B8962E;
  --color-sage:  #7A9E7E;
  --color-cream: #EDE8DC;
  --color-slate: #141B2D;

  --font-display: var(--font-display-next);
  --font-body:    var(--font-body-next);
  --font-mono:    var(--font-mono-next);
}

/* ─────────────────────────────────────────
   BASE RESET
───────────────────────────────────────── */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ─────────────────────────────────────────
   BASE BODY
───────────────────────────────────────── */
html {
  scroll-behavior: smooth;
  background-color: #0A0E1A;
  color: #EDE8DC;
  cursor: none;
}

body {
  background-color: #0A0E1A;
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─────────────────────────────────────────
   SCROLLBAR
───────────────────────────────────────── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: #0A0E1A; }
::-webkit-scrollbar-thumb { background: #1E3A5F; border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: #B8962E; }

/* ─────────────────────────────────────────
   SELECTION
───────────────────────────────────────── */
::selection {
  background-color: #B8962E;
  color: #0A0E1A;
}

/* ─────────────────────────────────────────
   SECTION BASE
───────────────────────────────────────── */
section {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
}

/* ─────────────────────────────────────────
   LOADING STATE
───────────────────────────────────────── */
body.is-loading {
  overflow: hidden;
}

/* ─────────────────────────────────────────
   UTILITIES
───────────────────────────────────────── */
.gold-rule {
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #B8962E 30%, #B8962E 70%, transparent 100%);
}

.hex-pattern-container {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

/* ─────────────────────────────────────────
   ANIMATIONS
───────────────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-in { animation: fadeIn 0.6s ease forwards; }

@keyframes traceRight {
  from { width: 0; }
  to   { width: 100%; }
}
@keyframes traceDown {
  from { height: 0; }
  to   { height: 100%; }
}
.trace-right { animation: traceRight 0.8s ease forwards; }
.trace-down  { animation: traceDown 0.8s ease 0.8s forwards; }
